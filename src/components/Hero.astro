---
import "../styles/Hero.css";
import content from "../data/en.json";
import images from "../data/images.json";
import { asset } from "../lib/assets";
---

<section
  class="hero"
  style={`
    --hero-bg-desktop-dark: url('${asset(images.hero.products.src)}');
    --hero-bg-desktop-light: url('${asset(images.hero.products["src-light"])}');
    --hero-bg-mobile-dark: url('${asset(images.hero.products.mobileSrc)}');
    --hero-bg-mobile-light: url('${asset(images.hero.products["mobileSrc-light"])}');
  `}
>
  <div class="hero__overlay">
    <div class="hero__content">
      <p class="hero__eyebrow">
        {content.hero.eyebrow}
      </p>

      <h1 class="hero__title">
        {content.hero.title}
      </h1>

      <p class="hero__description">
        {content.hero.description}
      </p>

      <div class="hero__actions">
        <a class="hero__cta hero__cta--primary" href="#contact">
          {content.hero.primaryCta}
        </a>

        <a class="hero__cta hero__cta--secondary" href="#brands">
          {content.hero.secondaryCta}
        </a>
      </div>
    </div>
  </div>
</section>